@page
@model TimeLedger.Pages.Events.IndexModel
@{
    ViewData["Title"] = "My Events";
}

<div class="page-header">
    <div>
        <h1>My Events</h1>
        <p class="page-subtitle">Your schedule, grouped by day.</p>
    </div>
    <a class="btn-add" href="/Events/Create">+ New Event</a>
</div>

@if (!Model.Events.Any())
{
    <div class="empty-state">
        <p>No events yet. Create your first one.</p>
        <a class="btn-add" href="/Events/Create">Create Event</a>
    </div>
}
else
{
    var groupedEvents = Model.Events
        .OrderBy(e => e.StartTime)
        .GroupBy(e => e.StartTime.Date);

    foreach (var group in groupedEvents)
    {
        var isToday = group.Key == DateTime.Today;

        <section class="date-group">
            <h2 class="date-heading">
                @group.Key.ToString("dddd, dd MMM yyyy")
                @if (isToday)
                {
                    <span class="today-badge">Today</span>
                }
            </h2>

            @foreach (var e in group)
            {
                <div class="event-card">
                    <div class="event-card-left">
                        <span class="event-title">@e.Title</span>
                        <div class="event-meta">
                            @if (e.StartTime.Date == e.EndTime.Date)
                            {
                                <span>⏱ @e.StartTime.ToString("HH:mm") - @e.EndTime.ToString("HH:mm")</span>
                            }
                            else
                            {
                                <span>⏱ @e.StartTime.ToString("dd MMM HH:mm") - @e.EndTime.ToString("dd MMM HH:mm")</span>
                            }
                            <span class="event-duration">@e.Duration</span>
                            @if (!string.IsNullOrWhiteSpace(e.Location))
                            {
                                <span class="event-location">📍 @e.Location</span>
                            }
                        </div>
                        @if (!string.IsNullOrWhiteSpace(e.Description))
                        {
                            <span class="event-description">@e.Description</span>
                        }
                    </div>

                    <div class="event-card-actions">
                        <a href="/Events/Edit/@e.Id">Edit</a>
                        <a href="/Events/Delete/@e.Id">Delete</a>
                    </div>
                </div>
            }
        </section>
    }
}