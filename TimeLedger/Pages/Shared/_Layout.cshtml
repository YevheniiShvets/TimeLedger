@using Microsoft.AspNetCore.Http
@using TimeLedger.Services
@{
    var accountName = Context.Session.GetString(AuthSession.UserNameKey);
    var accountEmail = Context.Session.GetString(AuthSession.UserEmailKey);
    var isSignedIn = !string.IsNullOrWhiteSpace(accountEmail);
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - TimeLedger</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/TimeLedger.styles.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/css/layout.css" />
    <link rel="stylesheet" href="~/css/events.css" />
    <link rel="stylesheet" href="~/css/forms.css" />
</head>
<body>
<div class="app-layout">
    <aside class="sidebar">
        <div class="sidebar-header">
            <span class="sidebar-icon">📅</span>
            <div>
                <h2>TimeLedger</h2>
                <p>Manage your schedule</p>
            </div>
        </div>

        <a href="/Events/Create" class="btn-add">+ Add Event</a>

        <nav class="sidebar-nav">
            <p class="nav-label">Views</p>
            <a href="/Events" class="nav-link">Day View</a>
        </nav>

        <div class="sidebar-footer">
            @if (isSignedIn)
            {
                <div class="account-box">
                    <p class="account-name">@accountName</p>
                    <p class="account-email">@accountEmail</p>
                </div>
                <form method="post" asp-page="/Account/Logout">
                    <button type="submit" class="nav-link nav-link-button">Log Out</button>
                </form>
            }
            else
            {
                <p class="nav-label">Account</p>
                <a href="/Account/Login" class="nav-link">Log In</a>
                <a href="/Account/Register" class="nav-link">Register</a>
            }
        </div>
    </aside>

    <main class="main-content">
        @RenderBody()
    </main>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>