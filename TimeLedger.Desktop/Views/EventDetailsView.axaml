<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TimeLedger.Desktop.ViewModels"
             x:Class="TimeLedger.Desktop.Views.EventDetailsView"
             x:DataType="vm:EventDetailsViewModel"
             HorizontalAlignment="Stretch" VerticalAlignment="Stretch">

    <StackPanel Margin="40" MaxWidth="700" Spacing="20">

        <Button Content="← Back to Calendar" Command="{Binding BackCommand}"
                Background="Transparent" Foreground="#4B5563" BorderThickness="0"
                HorizontalAlignment="Left" Padding="0"/>

        <StackPanel Spacing="4">
            <TextBlock Text="Event Details" FontSize="28" FontWeight="Bold" Foreground="#111827"/>
            <TextBlock Text="Full details for this activity" FontSize="14" Foreground="#6B7280"/>
        </StackPanel>

        <Border Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="25">
            <StackPanel Spacing="8">
                <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="17" Foreground="#111827"/>
                <TextBlock Foreground="#4B5563" FontSize="14">
                    <Run Text="Type: "/><Run Text="{Binding EventTypeText}"/>
                </TextBlock>
                <TextBlock Text="{Binding TimeRangeText}" FontSize="14" Foreground="#4B5563"/>
                <TextBlock IsVisible="{Binding HasLocation}" FontSize="14" Foreground="#4B5563">
                    <Run Text="Location: "/><Run Text="{Binding Location}"/>
                </TextBlock>
                <TextBlock Text="{Binding RecurrenceInfo}" IsVisible="{Binding HasRecurrenceInfo}"
                           FontSize="14" Foreground="#2563EB"/>
                <TextBlock Text="{Binding Description}" IsVisible="{Binding HasDescription}"
                           FontSize="14" Foreground="#374151" TextWrapping="Wrap" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <StackPanel Orientation="Horizontal" Spacing="12">
            <Button Content="Edit" Command="{Binding EditCommand}"
                    Background="#111827" Foreground="White" Height="38" CornerRadius="6"
                    Padding="20,0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                    FontWeight="SemiBold"/>
            <Button Content="Delete" Command="{Binding DeleteCommand}"
                    Background="White" Foreground="#EF4444" BorderBrush="#FEE2E2" BorderThickness="1"
                    Height="38" CornerRadius="6" Padding="20,0"
                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
            <Button Content="Back" Command="{Binding BackCommand}"
                    Background="White" Foreground="#111827" BorderBrush="#D1D5DB" BorderThickness="1"
                    Height="38" CornerRadius="6" Padding="20,0"
                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
        </StackPanel>
    </StackPanel>
</UserControl>