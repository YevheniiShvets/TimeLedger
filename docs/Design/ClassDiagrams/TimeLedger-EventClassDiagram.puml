@startuml
left to right direction
skinparam classAttributeIconSize 0
skinparam packageStyle rectangle
skinparam linetype ortho
skinparam nodesep 45
skinparam ranksep 55
hide empty members

title TimeLedger - Event Layered Class Diagram

package "Presentation Layer" #E3F2FD {
  class "Event Pages" as EventPages
  
}
package DTOs{
    class "Event DTOs" as EventDTOs
      class SyncResultDto {
      +PushedCount: int
      +PulledCount: int
      +SyncedAt: DateTime
      +Error: string?
      }
}
package "Business Logic Layer" #E8F5E9 {

package "Core Library" #EDE7F6 {

interface ISettingsStore{
          +Get<T>(key: string): T?
          +Set<T>(key: string, value: T): void
}
class LocalSettingsStore  implements ISettingsStore{
      -_filePath: string
}

enum SyncMode {
Auto
Manual
}
       
  interface IConnectivityService{
    +IsAvailable(): bool
  }
  class ConnectivityService  implements IConnectivityService{
  -_remoteUrl: string
  +IsAvailable(): bool
  }
  
  interface ISyncStateStore{
            +GetLastSyncedAt(userId: int): DateTime?
            +SetLastSyncedAt(userId: int, at: DateTime): void
  }
  class LocalSyncStateStore  implements ISyncStateStore{
        -_filePath: string
  }
  
  class RecurrenceService {
    + GenerateOccurrences(eventStart: DateTime,eventEnd: DateTime, recurrence: RecurrenceRuleDto, rangeStart: DateTime, 
        rangeEnd: DateTime): IEnumerable<(DateTime, DateTime)>
  }

  class EventService {
    - repo: IEventRepository
  }

  class EventOccurrenceService {
    - eventRepository: IEventRepository
    - recurrenceService: IRecurrenceService
  }
}
}
package "Core Model" #EDE7F6 {
  class Event {
    + Id: int
    + OwnerId: int
    + Title: string
    + Description: string?
    + Location: string?
    + AllowOverlap: bool
    + StartTime: DateTime?
    + EndTime: DateTime?
    + DueAt: DateTime?
    + RecurrenceInterval: int?
    + RecurrenceValue: string?
    + RecurrenceEndTime: DateTime?
    + RecurrenceMaxOccurrences: int?
    + UpdatedAt: DateTime
    +IsDeleted: bool
  }

  enum EventOwnerType {
    User
    Group
  }

  enum EventType {
    OneTime
    Recurrence
    Deadline
  }

  enum RecurrenceFrequency
    {
        Daily
        Weekly
        Monthly
        Yearly
    }
}

package "Data Access Layer" #FFF3E0 {

class SyncService{
-remote: IEventRepository
-local: IEventRepository
-syncState: ISyncStateStore
-settings: ISettingsStore

+Sync(userId: int): SyncResult
+SyncOnStartup(userId: int): void
}

class SyncedEventRepository  implements IEventRepository{
-remote: IEventRepository
-local: IEventRepository
-connectivity: IConnectivityService

}

interface IEventRepository {
    + GetAll(ownerType: EventOwnerType, ownerId: int): IEnumerable<Event>
    + GetById(id: int, ownerType: EventOwnerType, ownerId: int): Event?
    + Add(e: Event): Event
    + Update(e: Event): Event
    + Delete(e: Event): void
    + HasOverlap(startTime: DateTime, endTime: DateTime, excludeId: int?, ownerType: EventOwnerType, ownerId: int): bool
    + GetOverlappingOwnerIds(startTime: DateTime, endTime: DateTime, excludeId: int?, ownerType: EventOwnerType, ownerIds: IEnumerable<int>): IEnumerable<int>
    + GetByType(EventType type, EventOwnerType ownerType, int ownerId) : IEnumerable<Event>
    +GetUpdatedSince(since: DateTime, ownerType: EventOwnerType, ownerId: int): IEnumerable<Event>
    +Upsert(e: Event): Event
  }
  
  package "Online Repository" #FFCCBC {
  class EventRepository {
    - _connectionString: string
  }
  }
  package "Local Repository" #FFE0B2 {
  class LocalEventRepository {
    - _filePath: string
   }

}

EventPages --> EventService
EventPages --> EventOccurrenceService
EventPages --> EventDTOs

EventService --> EventDTOs

EventService "1" --> "0..*" Event
EventService ..> IEventRepository

EventOccurrenceService --> EventDTOs
EventOccurrenceService --> Event

SyncService ..> IEventRepository

EventOccurrenceService ..> IEventRepository
EventOccurrenceService ..> RecurrenceService

IEventRepository <|.. EventRepository
IEventRepository <|.. LocalEventRepository

EventRepository "1" --> "0..*" Event
LocalEventRepository "1" --> "0..*" Event

Event "1" ..> "1" EventOwnerType
Event "1" ..> "1" EventType
Event "1" ..> "0..1" RecurrenceFrequency


@enduml
