@startuml
left to right direction
skinparam classAttributeIconSize 0
skinparam packageStyle rectangle
skinparam linetype ortho
skinparam nodesep 45
skinparam ranksep 55
hide empty members

title TimeLedger - Event Types Feature Design Class Diagram

package "Presentation" #E3F2FD {
  class "Event Pages" as EventPages
  class "Event DTOs" as EventDTOs
}

package "Service" #E8F5E9 {
  interface IEventService {
    + GetAll(ownerType: EventOwnerType, ownerId: int): IEnumerable<EventResponseDto>
    + GetById(id: int, ownerType: EventOwnerType, ownerId: int): EventResponseDto?
    + Create(dto: CreateEventDto, ownerType: EventOwnerType, ownerId: int): (EventResponseDto, bool)
    + Update(id: int, dto: UpdateEventDto, ownerType: EventOwnerType, ownerId: int): (EventResponseDto, bool)
    + Delete(id: int, ownerType: EventOwnerType, ownerId: int): void
  }

  interface IEventOccurrenceService {
    + GetOccurrencesInRange(ownerType: EventOwnerType, ownerId: int, rangeStart: DateTime, rangeEnd: DateTime): IEnumerable<EventOccurrenceDto>
    + GetOccurrencesForWeek(ownerType: EventOwnerType, ownerId: int, weekStartDate: DateTime): IEnumerable<EventOccurrenceDto>
  }

  interface IRecurrenceService {
    + GenerateOccurrences(eventStart: DateTime, eventEnd: DateTime, recurrence: RecurrenceRuleDto, rangeStart: DateTime, rangeEnd: DateTime): IEnumerable<(DateTime, DateTime)>
  }

  class EventService {
    - repo: IEventRepository
  }

  class EventOccurrenceService {
    - eventRepository: IEventRepository
    - recurrenceService: IRecurrenceService
  }

  class RecurrenceService {
    + GenerateOccurrences(eventStart: DateTime, eventEnd: DateTime, recurrence: RecurrenceRuleDto, rangeStart: DateTime, rangeEnd: DateTime): IEnumerable<(DateTime, DateTime)>
  }

  class RecurrenceInfoFormatter {
    + {static} Generate(e: Event): string?
    + {static} GetRecurrenceUnit(frequency: RecurrenceFrequency, singular: bool): string
  }
}

package "Core Model" #EDE7F6 {
  class Event {
    + Id: int
    + OwnerType: EventOwnerType
    + OwnerId: int
    + Title: string
    + Description: string?
    + Location: string?
    + AllowOverlap: bool
    + EventType: EventType
    + StartTime: DateTime?
    + EndTime: DateTime?
    + DueAt: DateTime?
    + RecurrenceFrequency: RecurrenceFrequency?
    + RecurrenceInterval: int?
    + RecurrenceValue: string?
    + RecurrenceEndTime: DateTime?
    + RecurrenceMaxOccurrences: int?
  }

  enum EventOwnerType {
    User
    Group
  }

  enum EventType {
    OneTime
    Recurrence
    Deadline
  }

  enum RecurrenceFrequency {
    Daily
    Weekly
    Monthly
    Yearly
  }
}

package "DTOs" #F3E5F5 {
  class CreateEventDto {
  }

  class UpdateEventDto {
  }

  class EventResponseDto {

  }

  class EventOccurrenceDto {
  }

  class RecurrenceRuleDto {
  }
}

package "Repository" #FFF3E0 {
  interface IEventRepository {
    + GetAll(ownerType: EventOwnerType, ownerId: int): IEnumerable<Event>
    + GetById(id: int, ownerType: EventOwnerType, ownerId: int): Event?
    + Add(e: Event): Event
    + Update(e: Event): Event
    + Delete(e: Event): void
    + HasOverlap(start: DateTime, end: DateTime, excludeId: int?, ownerType: EventOwnerType, ownerId: int): bool
    + GetOverlappingOwnerIds(start: DateTime, end: DateTime, excludeId: int?, ownerType: EventOwnerType, ownerIds: IEnumerable<int>): IEnumerable<int>
  }

  class EventRepository {
    - _connectionString: string
  }

  class InMemoryEventRepository {
    - _events: List<Event>
    - _nextId: int
  }
}

EventPages --> IEventService
EventPages --> IEventOccurrenceService
EventPages --> EventDTOs
EventDTOs --> DTOs
IEventService <|.. EventService
IEventOccurrenceService <|.. EventOccurrenceService
IRecurrenceService <|.. RecurrenceService
EventService --> IEventRepository
EventOccurrenceService --> IEventRepository
EventOccurrenceService --> IRecurrenceService
EventOccurrenceService --> DTOs

EventService --> RecurrenceInfoFormatter
EventOccurrenceService --> RecurrenceInfoFormatter

RecurrenceInfoFormatter --> Event
RecurrenceInfoFormatter --> RecurrenceFrequency

IEventRepository <|.. EventRepository
IEventRepository <|.. InMemoryEventRepository
EventRepository --> Event
InMemoryEventRepository --> Event

Event "1" ..> "1" EventType
Event "1" ..> "1" EventOwnerType
Event "1" ..> "0..1" RecurrenceFrequency
CreateEventDto "1" ..> "1" EventType
UpdateEventDto "1" ..> "1" EventType
RecurrenceRuleDto "1" ..> "1" RecurrenceFrequency


@enduml