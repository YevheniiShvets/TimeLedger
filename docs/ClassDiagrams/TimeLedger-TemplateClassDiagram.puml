@startuml
top to bottom direction
skinparam packageStyle rectangle
skinparam linetype ortho
skinparam classAttributeIconSize 0
skinparam nodesep 30
skinparam ranksep 50
hide empty members

title TimeLedger - High Level Layered Architecture

package "Presentation" as Presentation #E3F2FD {
  class "Presentation Pages" as PresentationPages <<UI>>
}

package "Service" as Service #E8F5E9 {
  interface ServiceInterface <<Interface>>
  class ServiceClass <<Service>>
}

package "Contracts / DTOs" as DTOs #F3E5F5 {
  class DTO <<DTO>>
}

package "Core Model" as CoreModel #EDE7F6 {
  class Model <<Entity>>
}

package "Repository / Data Access" as Repository #FFF3E0 {
  interface RepositoryInterface <<Interface>>
  class RepositoryClass <<Repository>>
}

Presentation -down-> ServiceInterface
Presentation ..> DTOs
ServiceInterface <|.. ServiceClass
ServiceClass ..> DTOs
ServiceClass -down..> RepositoryInterface
RepositoryInterface <|.. RepositoryClass
ServiceClass -down-> CoreModel
Repository -down-> CoreModel

' Layout hints to keep lanes separated and reduce arrow crossings


@enduml