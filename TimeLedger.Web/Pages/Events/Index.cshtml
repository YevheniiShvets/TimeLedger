@page
@model TimeLedger.Pages.Events.IndexModel
@using TimeLedger.Core.Models.Events
@{
    ViewData["Title"] = "My Events";
}

<div class="page-header">
    <div>
        <h1>My Events</h1>
        <p class="page-subtitle">Your schedule, grouped by day.</p>
    </div>
    <a class="btn-add" asp-page="/Events/Create">+ New Event</a>
</div>

@if (!Model.Events.Any())
{
    <div class="empty-state">
        <p>No events yet. Create your first one.</p>
        <a class="btn-add" asp-page="/Events/Create">Create Event</a>
    </div>
}
else
{
    var groupedEvents = Model.Events
        .OrderBy(e => e.StartTime)
        .GroupBy(e => {
            if (e.StartTime != null)
            {
                return e.StartTime.Value.Date;
            }
            else if (e.EndTime != null)
            {
                return e.EndTime.Value.Date;
            }
            else
            {
                return DateTime.MinValue.Date;
            }
        });
    

    foreach (var group in groupedEvents)
    {
        var isToday = group.Key == DateTime.Today;

        <section class="date-group">
            <h2 class="date-heading">
                @group.Key.ToString("dddd, dd MMM yyyy")
                @if (isToday)
                {
                    <span class="today-badge">Today</span>
                }
            </h2>

            @foreach (var e in group)
            {
                var typeClass = e.EventType switch
                {
                    EventType.Recurrence => "event-recurring",
                    EventType.Deadline => "event-deadline",
                    _ => "event-onetime"
                };

                <div class="event-card @typeClass" data-href="@Url.Page("/Events/Details", new { id = e.Id })">
                    <div class="event-card-left">
                        <span class="event-title">@e.Title</span>
                        <div class="event-meta">
                            @if (e.EventType == EventType.Deadline)
                            {
                                <span>📅 Due at @e.StartTime?.ToString("HH:mm")</span>
                            }
                            else if (e.StartTime != null && e.EndTime != null && e.StartTime.Value.Date == e.EndTime.Value.Date)
                            {
                                <span>⏱ @e.StartTime.Value.ToString("HH:mm") - @e.EndTime.Value.ToString("HH:mm")</span>
                                <span class="event-duration">@e.Duration</span>
                            }
                            else
                            {
                                <span>⏱ @e.StartTime?.ToString("dd MMM HH:mm") - @e.EndTime?.ToString("dd MMM HH:mm")</span>
                                <span class="event-duration">@e.Duration</span>
                            }
                            @if (!string.IsNullOrWhiteSpace(e.RecurrenceInfo))
                            {
                                <span class="event-recurrence">🔄 @e.RecurrenceInfo</span>
                            }
                            @if (!string.IsNullOrWhiteSpace(e.Location))
                            {
                                <span class="event-location">📍 @e.Location</span>
                            }
                        </div>
                        @if (!string.IsNullOrWhiteSpace(e.Description))
                        {
                            <span class="event-description">@e.Description</span>
                        }
                    </div>

                    <div class="event-card-actions">
                        <a asp-page="/Events/Edit" asp-route-id="@e.Id">Edit</a>
                        <a asp-page="/Events/Delete" asp-route-id="@e.Id">Delete</a>
                    </div>
                </div>
            }
        </section>
    }
}

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const cards = document.querySelectorAll('.event-card[data-href]');
        cards.forEach(card => {
            card.addEventListener('click', function(event) {
                if (event.target.closest('a')) {
                    return;
                }
                const href = card.getAttribute('data-href');
                if (href) {
                    window.location.href = href;
                }
            });
        });
    });
</script>
