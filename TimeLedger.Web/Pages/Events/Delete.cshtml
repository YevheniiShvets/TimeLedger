@page "{id:int}"
@model TimeLedger.Pages.Events.DeleteModel
@{
    ViewData["Title"] = "Delete Event";
}

<div class="form-container">
    <a asp-page="/Events/Index" class="form-back">← Back to Calendar</a>
    <h1 class="form-title">Delete Activity</h1>
    <p class="form-subtitle">This action cannot be undone</p>

    <div class="delete-card">
        <p>Are you sure you want to delete this event?</p>
        <p><strong>@Model.Event.Title</strong></p>
        <p>
            @(Model.Event.StartTime.HasValue
                ? Model.Event.StartTime.Value.ToString("dd/MM/yyyy HH:mm")
                : "Time TBD")
            -
            @(Model.Event.EndTime.HasValue
                ? Model.Event.EndTime.Value.ToString("dd/MM/yyyy HH:mm")
                : "Time TBD")
        </p>
        @if (!string.IsNullOrWhiteSpace(Model.Event.Location))
        {
            <p>@Model.Event.Location</p>
        }
    </div>

    <form method="post">
        <div class="btn-row">
            <button type="submit" class="btn-danger">Delete</button>
            <a asp-page="/Events/Index" class="btn-secondary">Cancel</a>
        </div>
    </form>
</div>
