@page
@model TimeLedger.Pages.Groups.IndexModel
@{
    ViewData["Title"] = "Groups";
}
<div class="page-header">
    <div>
        <h1>Groups</h1>
        <p class="page-subtitle">Manage shared calendars and members.</p>
    </div>
    <a class="btn-add" asp-page="/Groups/Create">+ New Group</a>
</div>
@if (!Model.Groups.Any())
{
    <div class="empty-state">
        <p>No groups yet. Create your first group.</p>
        <a class="btn-add" asp-page="/Groups/Create">Create Group</a>
    </div>
}
else
{
    <section class="date-group">
        @foreach (var group in Model.Groups)
        {
            <div class="event-card">
                <div class="event-card-left">
                    <span class="event-title">@group.Name</span>
                    <div class="event-meta">
                        <span>Open group management</span>
                    </div>
                </div>
                <div class="event-card-actions">
                    <a asp-page="/Groups/ManageMembers" asp-route-id="@group.Id">@(group.OwnerId == Model.CurrentUserId ? "Manage Members" : "View Members")</a>
                    @if (group.OwnerId == Model.CurrentUserId)
                    {
                        <a asp-page="/Groups/Edit" asp-route-id="@group.Id">Edit</a>
                        <a asp-page="/Groups/Delete" asp-route-id="@group.Id">Delete</a>
                    }
                </div>
            </div>
        }
    </section>
}
