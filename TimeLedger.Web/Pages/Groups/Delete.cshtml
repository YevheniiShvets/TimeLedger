@page "{id:int}"
@model TimeLedger.Pages.Groups.Delete
@{
    ViewData["Title"] = "Delete Group";
}

<div class="form-container auth-form-container">
    <a asp-page="/Groups/Index" class="form-back">← Back to Groups</a>
    <h1 class="form-title">Delete Group</h1>
    <p class="form-subtitle">This action cannot be undone</p>

    <div class="delete-card">
        <p>Are you sure you want to delete this group?</p>
        <p><strong>@Model.Group.Name</strong></p>
        <p>Members: @Model.Group.Members.Count</p>
    </div>

    <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

    <form method="post" asp-route-id="@Model.Group.Id">
        <div class="btn-row">
            @if (Model.IsOwner)
            {
                <button type="submit" class="btn-danger">Delete Group</button>
            }
            <a asp-page="/Groups/Edit" asp-route-id="@Model.Group.Id" class="btn-secondary">Back to Edit</a>
            <a asp-page="/Groups/Index" class="btn-secondary">Cancel</a>
        </div>
    </form>

    @if (!Model.IsOwner)
    {
        <div class="empty-state">
            <p>Only the group owner can delete this group.</p>
        </div>
    }
</div>
