@page "{id:int}"
@model TimeLedger.Pages.Groups.ManageModel
@{
    ViewData["Title"] = "Manage Group";
}
<div class="form-container">
    <a asp-page="/Groups/Index" class="form-back">← Back to Groups</a>
    <h1 class="form-title">Manage Group</h1>
    <p class="form-subtitle">Edit group details and manage members</p>
    <form method="post" asp-page-handler="Update">
        <div class="form-group">
            <label asp-for="UpdateInput.Name">Group Name <span class="required">*</span></label>
            <input asp-for="UpdateInput.Name" />
            <span asp-validation-for="UpdateInput.Name" class="field-error"></span>
        </div>
        <div class="btn-row">
            <button type="submit" class="btn-primary">Save Group</button>
            <a asp-page="/Groups/Index" class="btn-secondary">Back</a>
        </div>
    </form>
    <hr />
    <h2 class="form-title">Members</h2>
    <p class="form-subtitle">Current members: @Model.Group.Members.Count</p>
    <form method="post" asp-page-handler="AddMember">
        <div class="form-row">
            <div class="form-group">
                <label asp-for="AddMemberInput.UserId">User Id <span class="required">*</span></label>
                <input asp-for="AddMemberInput.UserId" type="number" min="1" placeholder="e.g., 12" />
                <span asp-validation-for="AddMemberInput.UserId" class="field-error"></span>
            </div>
            <div class="form-group" style="display:flex;align-items:end;">
                <button type="submit" class="btn-primary">Add Member</button>
            </div>
        </div>
    </form>
    @if (!Model.Group.Members.Any())
    {
        <div class="empty-state">
            <p>No members yet.</p>
        </div>
    }
    else
    {
        foreach (var member in Model.Group.Members)
        {
            <div class="event-card">
                <div class="event-card-left">
                    <span class="event-title">@member.Name</span>
                    <div class="event-meta">
                        <span>@member.Email</span>
                        <span>Id: @member.Id</span>
                    </div>
                </div>
                <div class="event-card-actions">
                    <form method="post" asp-page-handler="RemoveMember" asp-route-userId="@member.Id">
                        <button type="submit" class="btn-danger">Remove</button>
                    </form>
                </div>
            </div>
        }
    }
    <div asp-validation-summary="ModelOnly" class="validation-summary"></div>
    <form method="post" asp-page-handler="Delete">
        <div class="btn-row">
            <button type="submit" class="btn-danger" onclick="return confirm('Delete this group?');">Delete Group</button>
        </div>
    </form>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
