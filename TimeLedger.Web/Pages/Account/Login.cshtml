@page
@model TimeLedger.Pages.Account.LoginModel
@{
	ViewData["Title"] = "Log In";
}

<div class="form-container auth-form-container">
	<a href="/Events" class="form-back">← Back to Calendar</a>
	<h1 class="form-title">Welcome back</h1>
	<p class="form-subtitle">Log in to continue managing your schedule</p>

	<form method="post">
		<div class="form-group">
			<label asp-for="Input.Email">Email <span class="required">*</span></label>
			<input asp-for="Input.Email" type="email" autocomplete="email" placeholder="you@example.com" />
			<span asp-validation-for="Input.Email" class="field-error"></span>
		</div>

		<div class="form-group">
			<label asp-for="Input.Password">Password <span class="required">*</span></label>
			<input asp-for="Input.Password" type="password" autocomplete="current-password" placeholder="Enter password" />
			<span asp-validation-for="Input.Password" class="field-error"></span>
		</div>

		<div asp-validation-summary="ModelOnly" class="validation-summary"></div>

		<div class="btn-row">
			<button type="submit" class="btn-primary">Log In</button>
			<a href="/Account/Register" class="btn-secondary">Create Account</a>
		</div>
	</form>
</div>

@section Scripts {
	<partial name="_ValidationScriptsPartial" />
}

