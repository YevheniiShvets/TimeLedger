@page
@model TimeLedger.Pages.Account.EditAccountModel
@{
    ViewData["Title"] = "Edit Account";
}

<div class="form-container auth-form-container">
    <a asp-page="/Account/Info" class="form-back">← Back to Account Info</a>
    <h1 class="form-title">Edit Account</h1>
    <p class="form-subtitle">Update your profile and credentials</p>

    <form method="post">
        <div class="form-group">
            <label asp-for="Input.Name">Name <span class="required">*</span></label>
            <input asp-for="Input.Name" autocomplete="name" placeholder="Your full name" />
            <span asp-validation-for="Input.Name" class="field-error"></span>
        </div>

        <div class="form-group">
            <label asp-for="Input.Email">Email <span class="required">*</span></label>
            <input asp-for="Input.Email" type="email" autocomplete="email" placeholder="you@example.com" />
            <span asp-validation-for="Input.Email" class="field-error"></span>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label asp-for="Input.Password">Password <span class="required">*</span></label>
                <input asp-for="Input.Password" type="password" autocomplete="new-password" placeholder="Enter new password" />
                <span asp-validation-for="Input.Password" class="field-error"></span>
            </div>
            <div class="form-group">
                <label asp-for="Input.ConfirmPassword">Confirm Password <span class="required">*</span></label>
                <input asp-for="Input.ConfirmPassword" type="password" autocomplete="new-password" placeholder="Repeat password" />
                <span asp-validation-for="Input.ConfirmPassword" class="field-error"></span>
            </div>
        </div>

        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

        <div class="btn-row">
            <button type="submit" class="btn-primary">Save Changes</button>
            <a asp-page="/Account/Info" class="btn-secondary">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

